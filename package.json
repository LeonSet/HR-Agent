{
  "name": "hr-agent",
  "version": "1.0.0",
  "description": "HR-Agent Prototyp – CAP Backend mit vw-doc-ai Integration und React Frontend",
  "dependencies": {
    "@sap/cds": "^9",
    "express": "^4",
    "multer": "^1"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch",
