{
  "name": "hr-agent",
  "version": "1.0.0",
  "description": "HR-Agent Prototyp – CAP Backend mit vw-doc-ai Integration und React Frontend",
  "dependencies": {
    "@sap/cds": "^9",
    "express": "^4",
    "multer": "^1",
    "openai": "^6.29.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2"
  },
  "scripts": {
    "db:deploy": "cds deploy --to sqlite:db.sqlite",
    "start": "npm run db:deploy && cds-serve",
    "dev": "npm run db:deploy && cds watch",
    "dev:app": "cd app && npm run dev",
    "test": "node --test tests/",
    "install:app": "cd app && npm install",
    "build:app": "cd app && npm run build"
  },
  "private": true,
  "cds": {
    "requires": {
      "db": "sqlite"
    }
  }
}
